#!/bin/bash

set -x

CURR_DIR=`cd $(dirname $0); pwd`
CORE=$CURR_DIR/core
POSTS=$CURR_DIR/source/_posts
PUB=$CURR_DIR/public
DROPBOX=/Users/ansvver/Dropbox/blog

cd $CURR_DIR
pyenv local anaconda3 || true

function _init() {
  cd $PUB
  rm *.html || true
  rm -r assets || true
  rm -r css || true
  rm -r js || true
  rm favicon.ico || true
  rm logo.png || true
  rm robots.txt || true
  rm custom.css || true

  cd $POSTS
  cp -r assets $PUB || true

  cd $POSTS/../
  cp -r css $PUB || true
  cp -r js $PUB || true
  cp favicon.ico $PUB || true
  cp logo.png $PUB || true
  cp robots.txt $PUB || true
  cp custom.css $PUB || true
}

function _genHomePage() {
  python3 $CORE/pages.py home
}

function _addComment() {
  python3 $CORE/pages.py comment
}

function _genPosts() {
  cd $POSTS
  jupyter nbconvert --output-dir $PUB --to html *.ipynb
  cd -
  [[ "$1" == "online" ]] && rm $PUB/draft*.html 1>/dev/null 2>&1
}

function export() {
  cd $DROPBOX
  rm -r assets || true
  rm -r *.md || true

  cd $POSTS
  cp -r assets $DROPBOX || true
  jupyter nbconvert --output-dir $DROPBOX --to markdown *.ipynb
  echo "export done"
}

function generate() {
  cd $CURR_DIR
  _init
  _genPosts $1
  _addComment
  _genHomePage
  echo "generate done"
}

function server() {
  cd $PUB
  python -m http.server
  cd -
}

function write() {
  cd $POSTS
  jupyter notebook &
  cd -
}

function quit() {
  ps -ef | grep "[j]upyter-notebook" | awk '{print $2}' | xargs kill
}

function deploy() {
  cd $CURR_DIR
  generate $1

  cd $CURR_DIR
  git add -u && git add -A source/_posts/* && git commit -m "Upload @`date +\"%y-%m-%d %H:%M:%S\"`" && git push origin source

  git checkout master
  cd $CURR_DIR
  ls -a | grep -v "public" | grep -v "\."|xargs rm -rf
  cp -r public/* .

  cd $CURR_DIR
  git add -u
  git add -A . && git commit -m "Deploy @`date +\"%y-%m-%d %H:%M:%S\"`" && git push origin master
  git checkout source
}

function echoUsage() {
  echo "Usage $0 [-h|-g|-s|-gs|-w|-q|-d|-rz]"
}

function resize() {
  python3 $CORE/resize.py $1
}

case "$1" in
  -h|help)
    echoUsage
    ;;
  -g|generate)
    generate
    ;;
  -s|server)
    server
    ;;
  -gs)
    generate
    server
    ;;
  -w|write)
    quit
    write
    ;;
  -q|quit)
    quit
    ;;
  -d|deploy)
    quit
    deploy "online"
    ;;
  -ex|export)
    export
    ;;
  -rz|resize)
    resize $2
    ;;
  *)
    echoUsage
    exit 1
    ;;
esac
